 251:Core/Src/system_stm32g0xx.c ****   /* Get SYSCLK source -------------------------------------------------------*/
 252:Core/Src/system_stm32g0xx.c ****   switch (RCC->CFGR & RCC_CFGR_SWS) {
  63              		.loc 1 252 3 view .LVU9
  64              		.loc 1 252 14 is_stmt 0 view .LVU10
  65 0002 284B     		ldr	r3, .L13
