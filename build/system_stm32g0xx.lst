 156:Core/Src/system_stm32g0xx.c **** /* The SystemCoreClock variable is updated in three ways:
 157:Core/Src/system_stm32g0xx.c ****     1) by calling CMSIS function SystemCoreClockUpdate()
 158:Core/Src/system_stm32g0xx.c ****     2) by calling HAL API function HAL_RCC_GetHCLKFreq()
 159:Core/Src/system_stm32g0xx.c ****     3) each time HAL_RCC_ClockConfig() is called to configure the system clock
 160:Core/Src/system_stm32g0xx.c ****    frequency Note: If you use this function to configure the system clock; then
 161:Core/Src/system_stm32g0xx.c ****    there is no need to call the 2 first functions listed above, since
 162:Core/Src/system_stm32g0xx.c ****    SystemCoreClock variable is updated automatically.
 163:Core/Src/system_stm32g0xx.c **** */
 164:Core/Src/system_stm32g0xx.c **** uint32_t SystemCoreClock = 16000000UL;
 165:Core/Src/system_stm32g0xx.c **** 
 166:Core/Src/system_stm32g0xx.c **** const uint32_t AHBPrescTable[16UL] = {0UL, 0UL, 0UL, 0UL, 0UL, 0UL, 0UL, 0UL,
 167:Core/Src/system_stm32g0xx.c ****                                       1UL, 2UL, 3UL, 4UL, 6UL, 7UL, 8UL, 9UL};
 168:Core/Src/system_stm32g0xx.c **** const uint32_t APBPrescTable[8UL] = {0UL, 0UL, 0UL, 0UL, 1UL, 2UL, 3UL, 4UL};
 169:Core/Src/system_stm32g0xx.c **** 
