1113:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c **** /**
1114:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   * @brief  USBD_CoreGetEPAdd
1115:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   *         Get the endpoint address relative to a selected class
1116:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   * @param  pdev: device instance
1117:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   * @param  ep_dir: USBD_EP_IN or USBD_EP_OUT
1118:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   * @param  ep_type: USBD_EP_TYPE_CTRL, USBD_EP_TYPE_ISOC, USBD_EP_TYPE_BULK or USBD_EP_TYPE_INTR
1119:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   * @param  ClassId: The Class ID
1120:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   * @retval Address of the selected endpoint or 0xFFU if no endpoint found.
1121:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   */
1122:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c **** uint8_t USBD_CoreGetEPAdd(USBD_HandleTypeDef *pdev, uint8_t ep_dir, uint8_t ep_type, uint8_t ClassI
1123:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c **** {
1124:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   uint8_t idx;
1125:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c **** 
1126:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   /* Find the EP address in the selected class table */
1127:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   for (idx = 0; idx < pdev->tclasslist[ClassId].NumEps; idx++)
1128:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   {
1129:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****     if (((pdev->tclasslist[ClassId].Eps[idx].add & USBD_EP_IN) == ep_dir) && \
1130:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****         (pdev->tclasslist[ClassId].Eps[idx].type == ep_type) && \
1131:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****         (pdev->tclasslist[ClassId].Eps[idx].is_used != 0U))
1132:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****     {
1133:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****       return (pdev->tclasslist[ClassId].Eps[idx].add);
1134:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****     }
1135:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   }
1136:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c **** 
1137:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   /* If reaching this point, then no endpoint was found */
1138:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c ****   return 0xFFU;
1139:Middlewares/ST/STM32_USB_Device_Library/Core/Src/usbd_core.c **** }
